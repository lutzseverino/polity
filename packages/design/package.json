{
  "name": "@polity/design",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "polity-design": "./bin/polity-design.mjs"
  },
  "exports": {
    ".": "./src/index.ts",
    "./tokens": "./src/tokens.ts",
    "./tokens.json": "./src/tokens.json"
  },
  "types": "./src/index.ts",
  "scripts": {
    "check:architecture": "depcruise --config dependency-cruiser.cjs src bin",
    "generate:shadcn-theme": "node bin/polity-design.mjs generate shadcn-theme",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
