{
  "standards-version": 3,
  "standards-release": "2.0.0",
  "boundaries": [
    {"path": ".", "type": "repository", "title": "Polity"},
    {"path": "apps", "type": "collection", "title": "Applications"},
    {"path": "apps/landing", "type": "project", "title": "Polity Landing"},
    {"path": "apps/mobile", "type": "project", "title": "Polity Mobile"},
    {"path": "apps/web", "type": "project", "title": "Polity Web"},
    {"path": "packages", "type": "collection", "title": "Packages"},
    {"path": "packages/design", "type": "project", "title": "Polity Design"},
    {"path": "services", "type": "collection", "title": "Services"},
    {"path": "services/polity", "type": "project", "title": "Polity Service"}
  ],
  "dependency-updates": [
    {"ecosystem": "github-actions", "directory": "/", "schedule": "weekly"},
    {"ecosystem": "npm", "directory": "/", "schedule": "weekly"},
    {"ecosystem": "maven", "directory": "/services/polity", "schedule": "weekly"}
  ],
  "github": {
    "repository": "lutzseverino/polity",
    "default-branch": "main",
    "settings": {
      "delete-branch-on-merge": true,
      "allow-squash-merge": true,
      "allow-merge-commit": false,
      "allow-rebase-merge": false
    },
    "ruleset": {
      "name": "Protect main",
      "required-status-checks": ["CI / Required", "PR Policy / Validate"],
      "require-current-branch": true,
      "required-approvals": 0,
      "allowed-merge-methods": ["squash"],
      "prevent-deletion": true,
      "prevent-force-push": true,
      "allow-bypass-actors": false
    }
  },
  "profiles": ["common", "documentation", "pnpm-workspace", "vite-react", "spring-boot"],
  "variables": {},
  "local-fragments": {
    ".gitignore": [".repository-standards/gitignore.local"]
  },
  "repository-owned": [
    "README.md",
    "LICENSE",
    "package.json",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    "apps/**",
    "packages/**",
    "services/**",
    "docs/README.md",
    "docs/decisions/**",
    "docs/explanation/**",
    "docs/how-to/**",
    "docs/reference/**",
    "docs/tutorials/**",
    ".github/workflows/ci.yml",
    ".github/workflows/cardo-compatibility.yml",
    ".github/workflows/release.yml"
  ]
}
