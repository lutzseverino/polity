{
  "name": "@polity/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "pnpm routes:generate && pnpm i18n:compile && tsc -b && vite build",
    "check:architecture": "depcruise --config dependency-cruiser.cjs src",
    "dev": "vite",
    "i18n:compile": "lingui compile --typescript",
    "i18n:extract": "lingui extract --clean",
    "i18n:sync": "pnpm i18n:extract && pnpm i18n:compile",
    "lint": "node ../../scripts/run-package-script.mjs root lint:ts:web",
    "preview": "vite preview",
    "routes:generate": "tsr generate",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "pnpm routes:generate && pnpm i18n:compile && tsc -b"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@lingui/core": "^6.5.0",
    "@lingui/react": "^6.5.0",
    "@shadcn/react": "^0.2.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "@vitejs/plugin-react": "^6.0.2",
    "axios": "^1.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.18.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^4.12.1",
    "recharts": "3.8.0",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@lingui/cli": "^6.5.0",
    "@lingui/vite-plugin": "^6.5.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tanstack/router-cli": "^1.167.18",
    "@tanstack/router-plugin": "^1.168.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-macros": "^3.1.0",
    "jsdom": "^29.1.1",
    "msw": "^2.15.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
