{
  "name": "@polity/landing",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "check:architecture": "depcruise --config dependency-cruiser.cjs src",
    "check:theme": "polity-design generate shadcn-theme --out src/design/tokens/shadcn-theme.css --check",
    "dev": "vite",
    "generate:api": "openapi-typescript ../../services/polity/openapi/polity.yaml -o src/api/generated/polity.ts",
    "generate:theme": "polity-design generate shadcn-theme --out src/design/tokens/shadcn-theme.css",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@fontsource-variable/big-shoulders-stencil-display": "^5.2.5",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@gsap/react": "^2.1.2",
    "@polity/design": "file:../../packages/design",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "i18next": "^26.3.1",
    "lucide-react": "^1.18.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "openapi-typescript": "^7.13.0",
    "typescript": "^6.0.3"
  }
}
